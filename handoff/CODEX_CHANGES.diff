# The worktree already contained uncommitted security/auth changes before this task.
# This manifest lists the production-audit additions and their behavioral intent,
# rather than claiming that the whole current git diff was created in this run.

diff --git a/.env.example b/.env.example
@@
-VITE_API_BASE_URL="http://localhost:3000"
+VITE_API_BASE_URL=

diff --git a/vite.config.ts b/vite.config.ts
@@
+Production ignores local .env API overrides, uses relative /api in the frontend,
+and rejects an explicitly supplied localhost/127.0.0.1 VITE_API_BASE_URL.

diff --git a/index.html b/index.html
@@
